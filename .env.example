# FitIntel Pro\.env.example
# ==========================================================
# FitIntel Pro - Example environment configuration
# ==========================================================

# ----------------------------------------------------------
# 1. General application settings
# ----------------------------------------------------------
APP_NAME=FitIntel Pro
APP_ENV=dev
APP_DEBUG=true
APP_HOST=0.0.0.0
APP_PORT=8000
API_V1_PREFIX=/api/v1
API_DOMAIN=http://localhost:8000
DOCS_ENABLED=true

# ----------------------------------------------------------
# 2. Security and JWT
# ----------------------------------------------------------
SECRET_KEY=change_me_super_secret_key
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ----------------------------------------------------------
# 3. PostgreSQL
# ----------------------------------------------------------
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5433
POSTGRES_DB=fitnexus_ai
POSTGRES_USER=fitnexus_user
POSTGRES_PASSWORD=FitNexus_User_2026!

# ----------------------------------------------------------
# 4. Redis
# ----------------------------------------------------------
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# ----------------------------------------------------------
# 5. CORS
# ----------------------------------------------------------
BACKEND_CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ----------------------------------------------------------
# 6. Logging and defaults
# ----------------------------------------------------------
LOG_LEVEL=INFO
DEFAULT_TIMEZONE=Europe/Berlin
DEFAULT_CURRENCY=RUB
MAINTENANCE_MODE=false

# ----------------------------------------------------------
# 7. Background tasks and monitoring
# ----------------------------------------------------------
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1
SENTRY_DSN=

# ----------------------------------------------------------
# 8. MAX Messenger (Push Notifications)
# ----------------------------------------------------------
MAX_BOT_TOKEN=
MAX_API_URL=https://api.max.ru
