pageType: content
background:
  type: solid
  color: "$background"
elements:
  - elementId: header-badge
    elementType: text
    bounds: [60, 24, 160, 20]
    content:
      style: "$badge"
      align: [left, middle]
      wrap: false
      text: FITNEXUS AI

  - elementId: page-title
    elementType: text
    bounds: [60, 60, 1100, 45]
    content:
      style: "$title"
      align: [left, middle]
      wrap: false
      text: |
        <p>10+ модулей в плане: <span style="color:$warning;">рекурренты, лояльность, ИИ-аналитика</span></p>

  - elementId: title-accent
    elementType: shape
    bounds: [60, 110, 50, 3]
    shapeName: rect
    fill:
      type: solid
      color: "$accent"

  - elementId: col1-bg
    elementType: shape
    bounds: [60, 135, 270, 265]
    shapeName: rect
    fill:
      type: solid
      color: "$surface"
    border:
      style: solid
      width: 1
      color: "$border"

  - elementId: col1-icon
    elementType: icon
    bounds: [80, 155, 24, 24]
    iconName: "fas:rotate"
    fill:
      type: solid
      color: "$warning"

  - elementId: col1-title
    elementType: text
    bounds: [112, 152, 200, 28]
    content:
      fontSize: 16
      color: "$text"
      fontFamily: "Liter"
      align: [left, middle]
      wrap: false
      text: Recurring Payments

  - elementId: col1-body
    elementType: text
    bounds: [80, 190, 230, 190]
    content:
      style: "$bodySmall"
      fontSize: 14
      lineHeight: 1.5
