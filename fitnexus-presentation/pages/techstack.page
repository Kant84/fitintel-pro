pageType: content
background:
  type: solid
  color: "$background"
elements:
  - elementId: header-badge
    elementType: text
    bounds: [60, 24, 160, 20]
    content:
      style: "$badge"
      align: [left, middle]
      wrap: false
      text: FITNEXUS AI

  - elementId: page-title
    elementType: text
    bounds: [60, 60, 1060, 45]
    content:
      style: "$title"
      align: [left, middle]
      wrap: false
      text: |
        <p>Python 3.12 + FastAPI + PostgreSQL — <span style="color:$primary;">зрелый стек для enterprise</span></p>

  - elementId: title-accent
    elementType: shape
    bounds: [60, 110, 50, 3]
    shapeName: rect
    fill:
      type: solid
      color: "$accent"

  - elementId: col1-bg
    elementType: shape
    bounds: [60, 135, 366, 400]
    shapeName: rect
    fill:
      type: solid
      color: "$surface"
    border:
      style: solid
      width: 1
      color: "$border"

  - elementId: col1-accent
    elementType: shape
    bounds: [60, 135, 366, 4]
    shapeName: rect
    fill:
      type: solid
      color: "$primary"

  - elementId: col1-icon
    elementType: icon
    bounds: [82, 158, 28, 28]
    iconName: "fas:code"
    fill:
      type: solid
      color: "$primary"

  - elementId: col1-title
    elementType: text
    bounds: [120, 155, 280, 35]
    content:
      style: "$sectionTitle"
      align: [left, middle]
      wrap: false
      text: Backend

  - elementId: col1-body
    elementType: text
    bounds: [82, 200, 320, 310]
    content:
      style: "$body"
      fontSize: 16
      lineHeight: 1.5
      align: [left, top]
      text: |
        <p><strong style="color:$primary;">Python 3.12+</strong></p>
        <p>FastAPI — async web framework</p>
        <p>SQLAlchemy 2 — ORM</p>
        <p>Alembic — миграции БД</p>
        <p>Pydantic — валидация</p>
        <p>JWT — аутентификация</p>
        <p style="margin-top:12px"><strong style="color:$primary;">Кэш / Очереди</strong></p>
        <p>Redis 7+ — сессии, кэш</p>
        <p>Celery — фоновые задачи</p>

  - elementId: col2-bg
    elementType: shape
    bounds: [446, 135, 366, 400]
    shapeName: rect
    fill:
      type: solid
      color: "$surface"
    border:
      style: solid
      width: 1
      color: "$border"

  - elementId: col2-accent
    elementType: shape
    bounds: [446, 135, 366, 4]
    shapeName: rect
    fill:
      type: solid
      color: "$accent"

  - elementId: col2-icon
    elementType: icon
    bounds: [468, 158, 28, 28]
    iconName: "fas:database"
    fill:
      type: solid
      color: "$accent"

  - elementId: col2-title
    elementType: text
    bounds: [506, 155, 300, 35]
    content:
      style: "$sectionTitle"
      align: [left, middle]
      wrap: false
      text: "База данных / Хранение"

  - elementId: col2-body
    elementType: text
    bounds: [468, 200, 320, 310]
    content:
      style: "$body"
      fontSize: 16
      lineHeight: 1.5
      align: [left, top]
      text: |
        <p><strong style="color:$accent;">PostgreSQL 16+</strong></p>
        <p>Master + Streaming Replica</p>
        <p>Hot standby failover</p>
        <p>WAL-архивирование</p>
        <p style="margin-top:12px"><strong style="color:$accent;">Инфраструктура</strong></p>
        <p>Docker + Docker Compose</p>
        <p>Nginx — reverse proxy</p>
        <p>Yandex Cloud (MVP)</p>
        <p>Kubernetes (Enterprise)</p>

  - elementId: col3-bg
    elementType: shape
    bounds: [832, 135, 388, 400]
    shapeName: rect
    fill:
      type: solid
      color: "$surface"
    border:
      style: solid
      width: 1
      color: "$border"

  - elementId: col3-accent
    elementType: shape
    bounds: [832, 135, 388, 4]
    shapeName: rect
    fill:
      type: solid
      color: "$success"

  - elementId: col3-icon
    elementType: icon
    bounds: [854, 158, 28, 28]
    iconName: "fas:rocket"
    fill:
      type: solid
      color: "$success"

  - elementId: col3-title
    elementType: text
    bounds: [892, 155, 300, 35]
    content:
      style: "$sectionTitle"
      align: [left, middle]
      wrap: false
      text: DevOps / Мониторинг

  - elementId: col3-body
    elementType: text
    bounds: [854, 200, 344, 310]
    content:
      style: "$body"
      fontSize: 16
      lineHeight: 1.5
      align: [left, top]
      text: |
        <p><strong style="color:$success;">IaC</strong></p>
        <p>Terraform 1.7+ — Yandex Cloud</p>
        <p>Ansible 2.16+ — конфигурация</p>
        <p style="margin-top:12px"><strong style="color:$success;">CI/CD</strong></p>
        <p>GitLab CI/CD pipeline</p>
        <p>ArgoCD (Enterprise)</p>
        <p style="margin-top:12px"><strong style="color:$success;">Monitoring</strong></p>
        <p>Zabbix 7.0 — инфраструктура</p>
        <p>Prometheus + Grafana</p>

  - elementId: bottom-note
    elementType: text
    bounds: [60, 555, 1160, 50]
    content:
      style: "$body"
      fontSize: 16
      align: [left, top]
      text: |
        <p><strong>Frontend:</strong> React 18+ / PWA  |  <strong>Тестирование:</strong> pytest, httpx  |  <strong>Безопасность:</strong> Vault, WireGuard, ModSecurity  |  <strong>Бэкапы:</strong> pg_dump, wal-g, restic</p>

  - elementId: bottom-accent
    elementType: shape
    bounds: [60, 690, 40, 3]
    shapeName: rect
    fill:
      type: solid
      color: "$accent"

  - elementId: page-num
    elementType: text
    bounds: [1180, 688, 40, 20]
    content:
      style: "$caption"
      align: [right, middle]
      wrap: false
      text: "06"