pageType: content
background:
  type: solid
  color: "$background"
elements:
  - elementId: header-badge
    elementType: text
    bounds: [60, 24, 160, 20]
    content:
      style: "$badge"
      align: [left, middle]
      wrap: false
      text: FITNEXUS AI

  - elementId: page-title
    elementType: text
    bounds: [60, 60, 1060, 45]
    content:
      style: "$title"
      align: [left, middle]
      wrap: false
      text: |
        <p>6 модулей реализовано: <span style="color:$success;">от аутентификации до финансовой кассы</span></p>

  - elementId: title-accent
    elementType: shape
    bounds: [60, 110, 50, 3]
    shapeName: rect
    fill:
      type: solid
      color: "$accent"

  - elementId: card1-bg
    elementType: shape
    bounds: [60, 135, 373, 230]
    shapeName: rect
    fill:
      type: solid
      color: "$surface"
    border:
      style: solid
      width: 1
      color: "$border"

  - elementId: card1-icon
    elementType: icon
    bounds: [80, 155, 32, 32]
    iconName: "fas:shield-halved"
    fill:
      type: solid
      color: "$primary"

  - elementId: card1-title
    elementType: text
    bounds: [122, 155, 290, 32]
    content:
      style: "$sectionTitle"
      fontSize: 20
      align: [left, middle]
      wrap: false
      text: Core Platform

  - elementId: card1-body
    elementType: text
    bounds: [80, 200, 333, 145]
    content:
      style: "$body"
      fontSize: 15
      lineHeight: 1.5
      align: [left, top]
      text: |
        <p><span style="color:$success;">✓</span> JWT + refresh-токены</p>
        <p><span style="color:$success;">✓</span> RBAC (7 ролей)</p>
        <p><span style="color:$success;">✓</span> Guard-правила</p>
