pageType: cover
background:
  type: solid
  color: "$background"
elements:
  - elementId: bg-img
    elementType: image
    bounds: [0, 0, 1280, 720]
    src: "/mnt/agents/output/fitnexus-presentation/images/9_Empty_Dark_Gym_Images_Browse_13_809.png"
    fit: {mode: cover}

  - elementId: bg-mask
    elementType: shape
    bounds: [0, 0, 1280, 720]
    shapeName: rect
    fill:
      type: gradient
      gradientType: linear
      angle: 90
      stops:
        - {position: 0, color: "#0B122000"}
        - {position: 0.3, color: "#0B122080"}
        - {position: 0.7, color: "#0B1220D0"}
        - {position: 1, color: "#0B1220F5"}

  - elementId: badge
    elementType: text
    bounds: [490, 200, 300, 24]
    content:
      style: "$badge"
      align: [center, middle]
      wrap: false
      text: |
        <p><span style="background-color:$primary; color:$white; font-size:12px;">  ТЕХНИЧЕСКОЕ ЗАДАНИЕ v2.0  </span></p>

  - elementId: main-title
    elementType: text
    bounds: [140, 250, 1000, 80]
    content:
      style: "$heroTitle"
      align: [center, middle]
      wrap: false
      text: |
        <p><span style="font-size:56px;">FitNexus AI</span></p>

  - elementId: divider-line
    elementType: shape
    bounds: [540, 350, 200, 3]
    shapeName: rect
    fill:
      type: solid
      color: "$accent"

  - elementId: subtitle
    elementType: text
    bounds: [240, 380, 800, 80]
    content:
      style: "$subtitle"
      align: [center, middle]
      text: |
        <p>Fitness OS: Модульная серверная платформа</p>
        <p>управления фитнес-клубом</p>

  - elementId: meta-info
    elementType: text
    bounds: [340, 490, 600, 30]
    content:
      style: "$caption"
      align: [center, middle]
      wrap: false
      text: |
        <p>Андрей Санакин (FixIntel)  |  29 мая 2026  |  Python 3.12 + FastAPI + PostgreSQL + React</p>

  - elementId: bottom-bar
    elementType: shape
    bounds: [0, 710, 1280, 10]
    shapeName: rect
    fill:
      type: gradient
      gradientType: linear
      angle: 0
      stops:
        - {position: 0, color: "$primary"}
        - {position: 0.5, color: "$accent"}
        - {position: 1, color: "$primary"}