pageType: table_of_contents
background:
  type: solid
  color: "$background"
elements:
  - elementId: header-badge
    elementType: text
    bounds: [60, 24, 160, 20]
    content:
      style: "$badge"
      align: [left, middle]
      wrap: false
      text: FITNEXUS AI

  - elementId: toc-title
    elementType: text
    bounds: [60, 60, 400, 50]
    content:
      style: "$title"
      align: [left, middle]
      wrap: false
      text: Содержание

  - elementId: accent-bar
    elementType: shape
    bounds: [60, 115, 60, 4]
    shapeName: rect
    fill:
      type: solid
      color: "$accent"

  - elementId: card-bg-1
    elementType: shape
    bounds: [60, 150, 360, 220]
    shapeName: rect
    fill:
      type: solid
      color: "$surface"
    border:
      style: solid
      width: 1
      color: "$border"

  - elementId: card-num-1
    elementType: text
    bounds: [85, 170, 60, 40]
    content:
      fontSize: 32
      color: "$primary"
      fontFamily: "Liter"
      align: [left, top]
      wrap: false
      text: "01"

  - elementId: card-icon-1
    elementType: icon
    bounds: [340, 170, 40, 40]
    iconName: "fas:info-circle"
    fill:
      type: solid
      color: "$primary"

  - elementId: card-title-1
    elementType: text
    bounds: [85, 220, 310, 30]
    content:
      style: "$sectionTitle"
      align: [left, middle]
      wrap: false
      text: Общие сведения

  - elementId: card-desc-1
    elementType: text
    bounds: [85, 260, 310, 80]
    content:
      style: "$bodySmall"
      align: [left, top]
      text: |
        <p>Проект, текущий статус реализации E0–E6 и ключевые цели платформы</p>

