  - elementId: left-content
    elementType: text
    bounds: [60, 285, 550, 310]
    content:
      style: "$body"
      align: [left, top]
      text: |
        <p><strong style="color:$primary;">FitNexus AI</strong> — модульная серверная платформа (Fitness OS), объединяющая:</p>
        <p style="margin-top:12px"><span style="color:$primary;">•</span> CRM — клиенты, абонементы, тарифы</p>
        <p><span style="color:$primary;">•</span> СКУД — QR/RFID, KERONG, шкафчики</p>
        <p><span style="color:$primary;">•</span> Финансы — кошельки, платежи, чеки ОФД</p>
        <p><span style="color:$primary;">•</span> Посещения — вход/выход, статистика</p>
        <p><span style="color:$primary;">•</span> Документооборот, ИИ-аналитика, лояльность</p>
