pageType: content
background:
  type: solid
  color: "$background"
elements:
  - elementId: header-badge
    elementType: text
    bounds: [60, 24, 160, 20]
    content:
      style: "$badge"
      align: [left, middle]
      wrap: false
      text: FITNEXUS AI

  - elementId: page-title
    elementType: text
    bounds: [60, 60, 1000, 45]
    content:
      style: "$title"
      align: [left, middle]
      wrap: false
      text: |
        <p>5 слоёв архитектуры: <span style="color:$primary;">от клиента до инфраструктуры</span></p>

  - elementId: title-accent
    elementType: shape
    bounds: [60, 110, 50, 3]
    shapeName: rect
    fill:
      type: solid
      color: "$accent"

  - elementId: layer5-bg
    elementType: shape
    bounds: [60, 130, 1160, 90]
    shapeName: rect
    fill:
      type: solid
      color: "#0D948815"
    border:
      style: solid
      width: 1
      color: "$primary"

  - elementId: layer5-num
    elementType: text
    bounds: [75, 140, 35, 30]
    content:
      fontSize: 18
      color: "$primary"
      fontFamily: "Liter"
      align: [center, middle]
      wrap: false
      text: "5"

  - elementId: layer5-title
    elementType: text
    bounds: [115, 138, 220, 30]
    content:
      fontSize: 16
      color: "$text"
      fontFamily: "Liter"
      align: [left, middle]
      wrap: false
      text: ИНФРАСТРУКТУРА

  - elementId: layer5-desc
    elementType: text
    bounds: [115, 170, 1080, 35]
    content:
      style: "$bodySmall"
      align: [left, top]
      text: |
        <p>Zabbix (серверы, сети, Docker)  |  Prometheus (метрики API, БД)  |  Grafana (дашборды, алерты)  |  Terraform  |  Ansible  |  GitLab CI/CD</p>

  - elementId: arrow5
    elementType: icon
    bounds: [620, 225, 20, 16]
    iconName: "fas:arrow-down"
    fill:
      type: solid
      color: "$primary"

  - elementId: layer4-bg
    elementType: shape
    bounds: [60, 248, 1160, 90]
    shapeName: rect
    fill:
      type: solid
      color: "#F9731615"
    border:
      style: solid
      width: 1
      color: "$accent"

  - elementId: layer4-num
