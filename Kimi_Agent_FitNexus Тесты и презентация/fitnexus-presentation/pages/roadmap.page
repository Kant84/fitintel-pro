pageType: content
background:
  type: solid
  color: "$background"
elements:
  - elementId: header-badge
    elementType: text
    bounds: [60, 24, 160, 20]
    content:
      style: "$badge"
      align: [left, middle]
      wrap: false
      text: FITNEXUS AI

  - elementId: page-title
    elementType: text
    bounds: [60, 60, 900, 45]
    content:
      style: "$title"
      align: [left, middle]
      wrap: false
      text: |
        <p>20 этапов: <span style="color:$primary;">от Foundation до нативных приложений</span></p>

  - elementId: title-accent
    elementType: shape
    bounds: [60, 110, 50, 3]
    shapeName: rect
    fill:
      type: solid
      color: "$accent"

  - elementId: timeline-line
    elementType: shape
    bounds: [60, 190, 1160, 0]
    shapeName: straightConnector1
    border: {style: solid, width: 2, color: "$border"}

  - elementId: dot-e0
    elementType: shape
    bounds: [85, 182, 16, 16]
    shapeName: ellipse
    fill:
      type: solid
      color: "$success"

  - elementId: dot-e6
    elementType: shape
    bounds: [545, 182, 16, 16]
    shapeName: ellipse
    fill:
      type: solid
      color: "$success"

  - elementId: dot-e10
    elementType: shape
    bounds: [775, 182, 16, 16]
    shapeName: ellipse
    fill:
      type: solid
      color: "$warning"

  - elementId: dot-e20
    elementType: shape
    bounds: [1155, 182, 16, 16]
    shapeName: ellipse
    fill:
      type: solid
      color: "$secondary"

  - elementId: label-e0
    elementType: text
    bounds: [60, 155, 80, 22]
    content:
      fontSize: 12
      color: "$success"
      fontFamily: "Liter"
      align: [center, middle]
      wrap: false
      text: E0 START

  - elementId: label-e6
    elementType: text
    bounds: [505, 155, 100, 22]
    content:
      fontSize: 12
      color: "$success"
      fontFamily: "Liter"
      align: [center, middle]
      wrap: false
      text: E6 DONE

  - elementId: label-e10
    elementType: text
    bounds: [745, 155, 80, 22]
    content:
      fontSize: 12
      color: "$warning"
      fontFamily: "Liter"
      align: [center, middle]
      wrap: false
      text: E10 NOW

  - elementId: label-e20
    elementType: text
    bounds: [1130, 155, 90, 22]
    content:
      fontSize: 12
      color: "$secondary"
      fontFamily: "Liter"
      align: [center, middle]
      wrap: false
      text: E20 FINAL

  - elementId: done-bg
    elementType: shape
    bounds: [60, 220, 500, 170]
    shapeName: rect
    fill:
      type: solid
      color: "#10B98110"
    border:
      style: solid
      width: 1
      color: "$success"

  - elementId: done-accent
    elementType: shape
    bounds: [60, 220, 500, 4]
    shapeName: rect
    fill:
      type: solid
      color: "$success"

  - elementId: done-title
    elementType: text
    bounds: [80, 236, 300, 28]
    content:
      fontSize: 18
      color: "$success"
      fontFamily: "Liter"
      align: [left, middle]
      wrap: false
      text: "✓ E0–E6 РЕАЛИЗОВАНО"

  - elementId: done-body
    elementType: text
    bounds: [80, 270, 460, 105]
    content:
      style: "$bodySmall"
      fontSize: 14
      lineHeight: 1.5
      align: [left, top]
      text: |
        <p>Foundation → Infrastructure → Core Platform → CRM → Access Control → Visits → Finance</p>
        <p style="margin-top:6px"><strong>Результат:</strong> 100+ API, 25+ таблиц, 7 ролей</p>

  - elementId: current-bg
    elementType: shape
    bounds: [580, 220, 330, 170]
    shapeName: rect
    fill:
      type: solid
      color: "#FBBF2410"
    border:
      style: solid
      width: 1
      color: "$warning"

  - elementId: current-accent
    elementType: shape
    bounds: [580, 220, 330, 4]
    shapeName: rect
    fill:
      type: solid
      color: "$warning"

  - elementId: current-title
    elementType: text
    bounds: [600, 236, 280, 28]
    content:
      fontSize: 18
      color: "$warning"
      fontFamily: "Liter"
      align: [left, middle]
      wrap: false
      text: "⚙ E7–E10 В РАБОТЕ"

  - elementId: current-body
    elementType: text
    bounds: [600, 270, 290, 105]
    content:
      style: "$bodySmall"
      fontSize: 14
      lineHeight: 1.5
      align: [left, top]
      text: |
        <p>IaC (Terraform + Ansible)</p>
        <p>Monitoring (Zabbix + Prometheus)</p>
        <p>Security & Compliance (152-ФЗ)</p>
        <p>High Availability (репликация)</p>

  - elementId: planned-bg
    elementType: shape
    bounds: [930, 220, 290, 170]
    shapeName: rect
    fill:
      type: solid
      color: "$surface"
    border:
      style: solid
      width: 1
      color: "$border"

  - elementId: planned-accent
    elementType: shape
    bounds: [930, 220, 290, 4]
    shapeName: rect
    fill:
      type: solid
      color: "$secondary"

  - elementId: planned-title
