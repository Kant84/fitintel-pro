    bounds: [950, 236, 250, 28]
    content:
      fontSize: 18
      color: "$secondary"
      fontFamily: "Liter"
      align: [left, middle]
      wrap: false
      text: "○ E11–E20 ПЛАН"

  - elementId: planned-body
