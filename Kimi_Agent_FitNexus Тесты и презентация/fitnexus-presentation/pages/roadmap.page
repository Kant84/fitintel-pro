  - elementId: p3-bg
    elementType: shape
    bounds: [820, 470, 400, 180]
    shapeName: rect
    fill:
      type: solid
      color: "$surface"
    border:
      style: solid
      width: 1
      color: "$secondary"

  - elementId: p3-num
    elementType: text
    bounds: [840, 480, 50, 40]
    content:
      fontSize: 28
      color: "$secondary"
      fontFamily: "Liter"
      align: [left, middle]
      wrap: false
      text: "3"

  - elementId: p3-title
    elementType: text
    bounds: [890, 482, 310, 30]
    content:
      fontSize: 16
      color: "$text"
      fontFamily: "Liter"
      align: [left, middle]
      wrap: false
