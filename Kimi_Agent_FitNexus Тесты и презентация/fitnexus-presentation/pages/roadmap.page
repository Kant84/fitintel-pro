    bounds: [950, 270, 250, 105]
    content:
      style: "$bodySmall"
      fontSize: 14
      lineHeight: 1.5
      align: [left, top]
      text: |
        <p>Documents → 1C → Admin Panel</p>
        <p>Client Cabinet PWA</p>
        <p>Loyalty → AI → Native Apps</p>

  - elementId: priority-title
    elementType: text
    bounds: [60, 415, 400, 30]
    content:
      style: "$sectionTitle"
      fontSize: 20
      align: [left, middle]
      wrap: false
