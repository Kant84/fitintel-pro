pageType: content
background:
  type: solid
  color: "$background"
elements:
  - elementId: header-badge
    elementType: text
    bounds: [60, 24, 160, 20]
    content:
      style: "$badge"
      align: [left, middle]
      wrap: false
      text: FITNEXUS AI

  - elementId: page-title
    elementType: text
    bounds: [60, 60, 1100, 45]
    content:
      style: "$title"
      align: [left, middle]
      wrap: false
      text: |
        <p>152-ФЗ + PCI DSS: <span style="color:$primary;">шифрование, сегментация, аудит</span></p>

  - elementId: title-accent
    elementType: shape
    bounds: [60, 110, 50, 3]
    shapeName: rect
    fill:
      type: solid
      color: "$accent"

  - elementId: network-bg
    elementType: shape
    bounds: [60, 135, 373, 245]
    shapeName: rect
    fill:
      type: solid
      color: "$surface"
    border:
      style: solid
      width: 1
      color: "$border"

  - elementId: network-accent
    elementType: shape
    bounds: [60, 135, 373, 4]
    shapeName: rect
    fill:
      type: solid
      color: "$primary"

  - elementId: network-icon
    elementType: icon
    bounds: [80, 155, 28, 28]
    iconName: "fas:network-wired"
    fill:
      type: solid
      color: "$primary"

  - elementId: network-title
    elementType: text
    bounds: [118, 153, 290, 30]
    content:
      style: "$sectionTitle"
      fontSize: 18
      align: [left, middle]
      wrap: false
      text: Сеть

  - elementId: network-body
    elementType: text
    bounds: [80, 195, 333, 170]
    content:
      style: "$bodySmall"
      fontSize: 15
      lineHeight: 1.55
      align: [left, top]
      text: |
        <p><span style="color:$primary;">•</span> DMZ/APP/DB/MON подсети</p>
        <p><span style="color:$primary;">•</span> Firewall: 80/443 снаружи</p>
        <p><span style="color:$primary;">•</span> SSH только через WireGuard VPN</p>
        <p><span style="color:$primary;">•</span> DDoS Yandex Cloud Protection</p>
        <p><span style="color:$primary;">•</span> Rate limiting 100 req/min</p>

  - elementId: app-bg
    elementType: shape
    bounds: [453, 135, 374, 245]
    shapeName: rect
    fill:
      type: solid
      color: "$surface"
    border:
      style: solid
      width: 1
      color: "$border"

  - elementId: app-accent
    elementType: shape
    bounds: [453, 135, 374, 4]
    shapeName: rect
    fill:
      type: solid
      color: "$accent"

  - elementId: app-icon
    elementType: icon
    bounds: [473, 155, 28, 28]
    iconName: "fas:code"
    fill:
      type: solid
      color: "$accent"

  - elementId: app-title
    elementType: text
    bounds: [511, 153, 290, 30]
    content:
      style: "$sectionTitle"
      fontSize: 18
      align: [left, middle]
      wrap: false
      text: Приложение

  - elementId: app-body
    elementType: text
    bounds: [473, 195, 334, 170]
    content:
      style: "$bodySmall"
      fontSize: 15
      lineHeight: 1.55
      align: [left, top]
      text: |
        <p><span style="color:$accent;">•</span> ModSecurity WAF (OWASP CRS)</p>
        <p><span style="color:$accent;">•</span> fail2ban: 5 попыток → бан 1ч</p>
        <p><span style="color:$accent;">•</span> HSTS, CSP, X-Frame-Options</p>
        <p><span style="color:$accent;">•</span> Pydantic валидация входных данных</p>
        <p><span style="color:$accent;">•</span> Защита SQLi через ORM</p>

  - elementId: data-bg
    elementType: shape
    bounds: [847, 135, 373, 245]
    shapeName: rect
    fill:
      type: solid
      color: "$surface"
    border:
      style: solid
      width: 1
      color: "$border"

  - elementId: data-accent
    elementType: shape
    bounds: [847, 135, 373, 4]
    shapeName: rect
    fill:
      type: solid
      color: "$success"

  - elementId: data-icon
    elementType: icon
    bounds: [867, 155, 28, 28]
    iconName: "fas:database"
    fill:
      type: solid
      color: "$success"

  - elementId: data-title
    elementType: text
    bounds: [905, 153, 290, 30]
    content:
      style: "$sectionTitle"
      fontSize: 18
      align: [left, middle]
      wrap: false
      text: Данные

  - elementId: data-body
    elementType: text
    bounds: [867, 195, 333, 170]
    content:
      style: "$bodySmall"
      fontSize: 15
      lineHeight: 1.55
      align: [left, top]
      text: |
        <p><span style="color:$success;">•</span> AES-256 для бэкапов</p>
        <p><span style="color:$success;">•</span> TLS 1.3 все соединения</p>
        <p><span style="color:$success;">•</span> bcrypt (12 rounds)</p>
        <p><span style="color:$success;">•</span> HashiCorp Vault секреты</p>
        <p><span style="color:$success;">•</span> PII анонимизация для ИИ</p>

  - elementId: law152-bg
    elementType: shape
    bounds: [60, 405, 560, 240]
    shapeName: rect
    fill:
      type: solid
      color: "$surface"
    border:
      style: solid
      width: 1
      color: "$warning"

  - elementId: law152-accent
    elementType: shape
    bounds: [60, 405, 4, 240]
    shapeName: rect
    fill:
      type: solid
      color: "$warning"

  - elementId: law152-icon
    elementType: icon
    bounds: [82, 425, 28, 28]
    iconName: "fas:file-shield"
    fill:
      type: solid
      color: "$warning"

  - elementId: law152-title
    elementType: text
    bounds: [120, 423, 400, 30]
    content:
      style: "$sectionTitle"
      fontSize: 18
      color: "$warning"
      align: [left, middle]
      wrap: false
      text: 152-ФЗ «О персональных данных»

  - elementId: law152-body
    elementType: text
    bounds: [82, 465, 520, 172]
    content:
      style: "$bodySmall"
      fontSize: 15
      lineHeight: 1.55
      align: [left, top]
      text: |
        <p><span style="color:$warning;">•</span> ПДн в зашифрованном виде (AES-256)</p>
        <p><span style="color:$warning;">•</span> PII отдельно от аналитических данных</p>
        <p><span style="color:$warning;">•</span> Журнал аудита: кто, когда, что — 5 лет</p>
        <p><span style="color:$warning;">•</span> Право на забвение (кроме 54-ФЗ)</p>
        <p><span style="color:$warning;">•</span> Согласия на обработку ПДн</p>
        <p><span style="color:$warning;">•</span> Учёт инцидентов для Роскомнадзора</p>

  - elementId: pci-bg
    elementType: shape
    bounds: [640, 405, 580, 240]
    shapeName: rect
    fill:
      type: solid
      color: "$surface"
    border:
      style: solid
      width: 1
      color: "$secondary"

  - elementId: pci-accent
    elementType: shape
    bounds: [640, 405, 4, 240]
    shapeName: rect
    fill:
      type: solid
      color: "$secondary"

  - elementId: pci-icon
    elementType: icon
    bounds: [662, 425, 28, 28]
    iconName: "fas:credit-card"
    fill:
      type: solid
      color: "$secondary"

  - elementId: pci-title
    elementType: text
    bounds: [700, 423, 400, 30]
    content:
      style: "$sectionTitle"
      fontSize: 18
      color: "$secondary"
      align: [left, middle]
      wrap: false
      text: PCI DSS (платёжные данные)

  - elementId: pci-body
    elementType: text
    bounds: [662, 465, 540, 165]
    content:
      style: "$bodySmall"
      fontSize: 15
      lineHeight: 1.55
      align: [left, top]
      text: |
        <p><span style="color:$secondary;">•</span> Не хранить CVV/CVC карт</p>
        <p><span style="color:$secondary;">•</span> Токены платёжных систем, не номера</p>
        <p><span style="color:$secondary;">•</span> Изоляция платёжного модуля</p>
        <p><span style="color:$secondary;">•</span> Логирование с контролем целостности</p>
        <p><span style="color:$secondary;">•</span> Отдельная сеть для платежей</p>

  - elementId: bottom-accent
    elementType: shape
    bounds: [60, 690, 40, 3]
    shapeName: rect
    fill:
      type: solid
      color: "$accent"

  - elementId: page-num
    elementType: text
    bounds: [1180, 688, 40, 20]
    content:
      style: "$caption"
      align: [right, middle]
      wrap: false
      text: "16"