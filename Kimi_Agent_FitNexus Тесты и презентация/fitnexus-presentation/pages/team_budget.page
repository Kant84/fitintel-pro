pageType: content
background:
  type: solid
  color: "$background"
elements:
  - elementId: header-badge
    elementType: text
    bounds: [60, 24, 160, 20]
    content:
      style: "$badge"
      align: [left, middle]
      wrap: false
      text: FITNEXUS AI

  - elementId: page-title
    elementType: text
    bounds: [60, 60, 1100, 45]
    content:
      style: "$title"
      align: [left, middle]
      wrap: false
      text: |
        <p>Команда 4–5 человек, бюджет 2–5M ₽: <span style="color:$primary;">запуск через 3 месяца</span></p>

  - elementId: title-accent
    elementType: shape
    bounds: [60, 110, 50, 3]
    shapeName: rect
    fill:
      type: solid
      color: "$accent"

  - elementId: team-table
    elementType: table
    bounds: [60, 135, 680, 250]
    style: "$default"
    columnWidths: [0.40, 0.15, 0.45]
    rowHeights: [0.155, 0.14125, 0.14125, 0.14125, 0.14125, 0.14125, 0.14125]
    rows:
      - - content: {text: "Роль", align: [left, middle]}
        - content: {text: "Кол-во", align: [center, middle]}
        - content: {text: "Комментарий", align: [left, middle]}
      - - content: {text: "Backend (Python/FastAPI)", align: [left, middle]}
        - content: {text: "1–2", align: [center, middle]}
        - content: {text: "Core разработчик + помощник", align: [left, middle]}
      - - content: {text: "DevOps / Инфраструктура", align: [left, middle]}
        - content: {text: "0.5–1", align: [center, middle]}
        - content: {text: "Terraform, Ansible, Zabbix, CI/CD", align: [left, middle]}
      - - content: {text: "Frontend (React/PWA)", align: [left, middle]}
        - content: {text: "1", align: [center, middle]}
        - content: {text: "Admin Panel + Client Cabinet", align: [left, middle]}
      - - content: {text: "QA / Тестирование", align: [left, middle]}
        - content: {text: "0.5", align: [center, middle]}
        - content: {text: "Автотесты + ручное тестирование", align: [left, middle]}
      - - content: {text: "Product Owner", align: [left, middle]}
        - content: {text: "0.5", align: [center, middle]}
        - content: {text: "Приоритизация, бизнес-метрики", align: [left, middle]}
      - - content: {text: "ML-инженер (опц.)", align: [left, middle]}
        - content: {text: "0.25", align: [center, middle]}
        - content: {text: "Внешний консультант для ИИ", align: [left, middle]}

  - elementId: budget-bg
    elementType: shape
    bounds: [770, 135, 450, 250]
    shapeName: rect
    fill:
      type: solid
      color: "$surface"
    border:
      style: solid
      width: 1
      color: "$border"

  - elementId: budget-title
    elementType: text
    bounds: [795, 155, 400, 30]
    content:
      style: "$sectionTitle"
      align: [left, middle]
      wrap: false
      text: Бюджет (оценочно)

  - elementId: budget-chart
    elementType: chart
    bounds: [785, 195, 420, 170]
    type: pie
    data:
      - {category: "Разработка", value: 3500}
      - {category: "Cloud", value: 200}
      - {category: "Лицензии", value: 75}
      - {category: "Поддержка", value: 900}
    x: category
    y: [value]
    colors: ["$primary", "$accent", "$warning", "$secondary"]
    options:
      innerRadius: 0.55
    legend: {position: right, color: "$text", fontSize: 12}
    dataLabels:
      show: true
      content: percentage
      numberFormat: "0%"
      color: "$text"
      fontSize: 11

  - elementId: risk-bg
    elementType: shape
    bounds: [60, 415, 1160, 240]
    shapeName: rect
    fill:
      type: solid
      color: "$surface"
    border:
      style: solid
      width: 1
      color: "$accent"

  - elementId: risk-accent
    elementType: shape
    bounds: [60, 415, 4, 240]
    shapeName: rect
    fill:
      type: solid
      color: "$accent"

  - elementId: risk-icon
    elementType: icon
    bounds: [82, 435, 28, 28]
    iconName: "fas:triangle-exclamation"
    fill:
      type: solid
      color: "$accent"

  - elementId: risk-title
    elementType: text
    bounds: [120, 433, 500, 30]
    content:
      style: "$sectionTitle"
      fontSize: 20
      color: "$accent"
      align: [left, middle]
      wrap: false
      text: "Главный риск: перегрузка функционалом"

  - elementId: risk-body
    elementType: text
    bounds: [82, 478, 1116, 155]
    content:
      style: "$body"
      fontSize: 16
      lineHeight: 1.6
      align: [left, top]
      text: |
        <p>~20 модулей для команды из 1–2 разработчиков = <strong style="color:$accent;">2–3 года разработки</strong>. Риск: проект «застрянет» на 80% готовности.</p>
        <p style="margin-top:10px"><strong style="color:$success;">Решение:</strong> Сократить MVP до 7 модулей — Core + CRM + Visits + Access Control + Finance + Admin Panel + Client Cabinet (PWA). Всё остальное — после первых платящих клиентов.</p>
        <p style="margin-top:10px"><strong style="color:$primary;">Вердикт:</strong> Сейчас вы на <strong>60% готовности</strong> к запуску первого клиента. Осталось: IaC, мониторинг, Admin Panel, Client Cabinet.</p>

  - elementId: bottom-accent
    elementType: shape
    bounds: [60, 690, 40, 3]
    shapeName: rect
    fill:
      type: solid
      color: "$accent"

  - elementId: page-num
    elementType: text
    bounds: [1180, 688, 40, 20]
    content:
      style: "$caption"
      align: [right, middle]
      wrap: false
      text: "19"