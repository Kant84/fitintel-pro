pageType: content
background:
  type: solid
  color: "$background"
elements:
  - elementId: header-badge
    elementType: text
    bounds: [60, 24, 160, 20]
    content:
      style: "$badge"
      align: [left, middle]
      wrap: false
      text: FIXINTEL PRO

  - elementId: page-title
    elementType: text
    bounds: [60, 60, 600, 45]
    content:
      style: "$title"
      align: [left, middle]
      wrap: false
      text: |
        <p>Для кого <span style="color:$primary;">подходит</span></p>

  - elementId: title-accent
    elementType: shape
    bounds: [60, 110, 50, 3]
    shapeName: rect
    fill:
      type: solid
      color: "$primary"

  - elementId: seg1-bg
    elementType: shape
    bounds: [60, 140, 270, 200]
    shapeName: rect
    fill:
      type: solid
      color: "$surface"
    border:
      style: solid
      width: 1
      color: "$border"

  - elementId: seg1-icon
    elementType: icon
    bounds: [80, 160, 32, 32]
    iconName: "fas:dumbbell"
    fill:
      type: solid
      color: "$primary"

  - elementId: seg1-title
    elementType: text
    bounds: [80, 200, 230, 25]
    content:
      fontSize: 16
      color: "$text"
      fontFamily: "Liter"
      align: [left, middle]
      wrap: false
      text: Тренажёрные залы

  - elementId: seg1-body
    elementType: text
    bounds: [80, 230, 230, 30]
    content:
      style: "$bodySmall"
      fontSize: 14
      lineHeight: 1.5
      align: [left, top]
      text: |
        <p>Контроль доступа, касса, CRM, учёт посещений</p>

  - elementId: seg2-bg
    elementType: shape
    bounds: [350, 140, 270, 200]
    shapeName: rect
    fill:
      type: solid
      color: "$surface"
    border:
      style: solid
      width: 1
      color: "$border"

  - elementId: seg2-icon
