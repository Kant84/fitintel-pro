      color: "$primary"

  - elementId: row2-title2
    elementType: text
    bounds: [519, 360, 290, 30]
    content:
      fontSize: 18
      color: "$text"
      fontFamily: "Liter"
      align: [left, middle]
      wrap: false
      text: Масштабирование

  - elementId: row2-body2
    elementType: text
    bounds: [473, 405, 334, 95]
    content:
      style: "$bodySmall"
      fontSize: 15
