      align: [left, top]
      text: |
        <p><strong style="color:$primary;">От 1 до 100+ клубов</strong></p>
        <p>Единая база, франчайзинг, корпоративный доступ</p>

  - elementId: row2-bg3
    elementType: shape
    bounds: [847, 340, 373, 180]
