    bounds: [867, 205, 333, 95]
    content:
      style: "$bodySmall"
      fontSize: 15
      lineHeight: 1.5
      align: [left, top]
      text: |
        <p><strong style="color:$success;">Контроль каждой копейки</strong></p>
        <p>Z-отчёты, чеки ОФД, защита от кассовых разрывов</p>

  - elementId: row2-bg1
