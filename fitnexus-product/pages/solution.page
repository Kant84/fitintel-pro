pageType: content
background:
  type: solid
  color: "$background"
elements:
  - elementId: header-badge
    elementType: text
    bounds: [60, 24, 160, 20]
    content:
      style: "$badge"
      align: [left, middle]
      wrap: false
      text: FIXINTEL PRO

  - elementId: page-title
    elementType: text
    bounds: [60, 60, 1000, 45]
    content:
      style: "$title"
      align: [left, middle]
      wrap: false
      text: |
        <p><span style="color:$primary;">FitIntel Pro</span> — автоматизация клуба за 1 день</p>

  - elementId: title-accent
    elementType: shape
    bounds: [60, 110, 50, 3]
    shapeName: rect
    fill:
      type: solid
      color: "$primary"

  - elementId: kpi1-bg
    elementType: shape
    bounds: [60, 140, 230, 100]
    shapeName: rect
    fill:
      type: solid
      color: "$surface"
    border:
      style: solid
      width: 1
      color: "$border"

  - elementId: kpi1-num
    elementType: text
    bounds: [75, 148, 200, 50]
    content:
      style: "$kpi"
      fontSize: 42
      align: [left, middle]
      wrap: false
      text: "30+"

  - elementId: kpi1-label
    elementType: text
    bounds: [75, 200, 200, 30]
    content:
      style: "$kpi_label"
      align: [left, middle]
      wrap: false
      text: "ЧАСОВ ЭКОНОМИИ / НЕДЕЛЯ"

  - elementId: kpi2-bg
    elementType: shape
    bounds: [305, 140, 230, 100]
    shapeName: rect
    fill:
      type: solid
      color: "$surface"
    border:
      style: solid
      width: 1
      color: "$border"

  - elementId: kpi2-num
    elementType: text
    bounds: [320, 148, 200, 50]
    content:
      style: "$kpi"
      fontSize: 42
      align: [left, middle]
      wrap: false
      text: "90%"

  - elementId: kpi2-label
    elementType: text
    bounds: [320, 200, 200, 30]
    content:
      style: "$kpi_label"
      align: [left, middle]
      wrap: false
      text: "СЕРЫХ ПРОХОДОВ УБРАНО"

  - elementId: kpi3-bg
    elementType: shape
    bounds: [550, 140, 230, 100]
    shapeName: rect
    fill:
      type: solid
      color: "$surface"
    border:
      style: solid
      width: 1
      color: "$border"

  - elementId: kpi3-num
    elementType: text
    bounds: [565, 148, 200, 50]
    content:
      style: "$kpi"
      fontSize: 42
      align: [left, middle]
      wrap: false
      text: "1 день"

  - elementId: kpi3-label
    elementType: text
    bounds: [565, 200, 200, 30]
    content:
      style: "$kpi_label"
      align: [left, middle]
      wrap: false
      text: "НА ЗАПУСК СИСТЕМЫ"

  - elementId: kpi4-bg
    elementType: shape
    bounds: [795, 140, 425, 100]
    shapeName: rect
    fill:
      type: solid
      color: "$surface"
    border:
      style: solid
      width: 1
      color: "$border"

  - elementId: kpi4-num
    elementType: text
    bounds: [810, 148, 200, 50]
    content:
      style: "$kpi"
      fontSize: 42
      align: [left, middle]
      wrap: false
      text: "99.9%"

  - elementId: kpi4-label
    elementType: text
    bounds: [810, 200, 395, 30]
    content:
      style: "$kpi_label"
      align: [left, middle]
      wrap: false
      text: "UPTIME — СИСТЕМА ВСЕГДА ДОСТУПНА"

  - elementId: features-title
    elementType: text
    bounds: [60, 270, 500, 30]
    content:
      style: "$sectionTitle"
      fontSize: 20
      color: "$primary"
      align: [left, middle]
      wrap: false
      text: Что включено «из коробки»

  - elementId: features-line
    elementType: shape
    bounds: [60, 300, 1160, 0]
    shapeName: straightConnector1
    border: {style: solid, width: 1, color: "$border"}

  - elementId: feat-left
    elementType: text
    bounds: [60, 320, 560, 280]
    content:
      style: "$body"
      fontSize: 17
      lineHeight: 1.6
      align: [left, top]
      text: |
        <p><span style="color:$primary;">✓</span> CRM — клиенты, абонементы, продажи</p>
        <p><span style="color:$primary;">✓</span> СКУД — QR/RFID, турникеты, шкафчики</p>
        <p><span style="color:$primary;">✓</span> Касса — платежи, чеки, ОФД, Z-отчёты</p>
        <p><span style="color:$primary;">✓</span> Учёт посещений — вход/выход за 0.5 сек</p>
        <p><span style="color:$primary;">✓</span> 7 ролей — от администратора до клиента</p>
        <p><span style="color:$primary;">✓</span> Офлайн-режим — работает без интернета</p>

  - elementId: feat-right
    elementType: text
    bounds: [640, 320, 580, 280]
    content:
      style: "$body"
      fontSize: 17
      lineHeight: 1.6
      align: [left, top]
      text: |
        <p><span style="color:$primary;">✓</span> 11 платёжных систем — СБП, карты, Apple Pay</p>
        <p><span style="color:$primary;">✓</span> REST API — интеграция с любыми системами</p>
        <p><span style="color:$primary;">✓</span> Шифрование данных — соответствие 152-ФЗ</p>
        <p><span style="color:$primary;">✓</span> Docker — развёртывание за 10 минут</p>
        <p><span style="color:$primary;">✓</span> Бэкапы каждые 6 часов</p>
        <p><span style="color:$primary;">✓</span> Облако или собственный сервер</p>

  - elementId: bottom-accent
    elementType: shape
    bounds: [60, 690, 40, 3]
    shapeName: rect
    fill:
      type: solid
      color: "$accent"

  - elementId: page-num
    elementType: text
    bounds: [1180, 688, 40, 20]
    content:
      style: "$caption"
      align: [right, middle]
      wrap: false
      text: "03"