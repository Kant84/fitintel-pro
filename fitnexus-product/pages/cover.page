pageType: cover
background:
  type: solid
  color: "$background"
elements:
  - elementId: bg-img
    elementType: image
    bounds: [0, 0, 1280, 720]
    src: "/mnt/agents/output/fitnexus-presentation/images/9_Empty_Dark_Gym_Images_Browse_13_809.png"
    fit: {mode: cover}

  - elementId: bg-mask
    elementType: shape
    bounds: [0, 0, 1280, 720]
    shapeName: rect
    fill:
      type: gradient
      gradientType: linear
      angle: 90
      stops:
        - {position: 0, color: "#0B122000"}
        - {position: 0.3, color: "#0B122080"}
        - {position: 0.7, color: "#0B1220D0"}
        - {position: 1, color: "#0B1220F5"}

  - elementId: badge
    elementType: text
    bounds: [440, 180, 400, 24]
    content:
      style: "$badge"
      align: [center, middle]
      wrap: false
      text: |
        <p><span style="background-color:$primary; color:$white; font-size:12px;">  ПЛАТФОРМА УПРАВЛЕНИЯ ФИТНЕС-КЛУБОМ  </span></p>

  - elementId: main-title
    elementType: text
    bounds: [140, 230, 1000, 80]
    content:
      style: "$heroTitle"
      align: [center, middle]
      wrap: false
      text: |
        <p><span style="font-size:56px;">FitIntel Pro</span></p>

  - elementId: divider-line
    elementType: shape
    bounds: [540, 330, 200, 3]
    shapeName: rect
    fill:
      type: solid
      color: "$accent"

  - elementId: subtitle
    elementType: text
    bounds: [190, 360, 900, 80]
    content:
      style: "$subtitle"
      fontSize: 22
      align: [center, middle]
      text: |
        <p>Единая цифровая платформа управления фитнес-клубом</p>
        <p>Всё под контролем — от входа клиента до отчёта в налоговую</p>

  - elementId: bottom-bar
    elementType: shape
    bounds: [0, 710, 1280, 10]
    shapeName: rect
    fill:
      type: gradient
      gradientType: linear
      angle: 0
      stops:
        - {position: 0, color: "$primary"}
        - {position: 0.5, color: "$accent"}
        - {position: 1, color: "$primary"}