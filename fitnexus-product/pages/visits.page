pageType: content
background:
  type: solid
  color: "$background"
elements:
  - elementId: header-badge
    elementType: text
    bounds: [60, 24, 160, 20]
    content:
      style: "$badge"
      align: [left, middle]
      wrap: false
      text: FIXINTEL PRO

  - elementId: page-title
    elementType: text
    bounds: [60, 60, 900, 45]
    content:
      style: "$title"
      align: [left, middle]
      wrap: false
      text: |
        <p>Visits — <span style="color:$warning;">цифры, а не догадки</span></p>

  - elementId: title-accent
    elementType: shape
    bounds: [60, 110, 50, 3]
    shapeName: rect
    fill:
      type: solid
      color: "$warning"

  - elementId: kpi1-bg
    elementType: shape
    bounds: [60, 135, 270, 110]
    shapeName: rect
    fill:
      type: solid
      color: "$surface"
    border:
      style: solid
      width: 1
      color: "$border"

  - elementId: kpi1-num
    elementType: text
    bounds: [75, 145, 240, 50]
    content:
      style: "$kpi"
      fontSize: 40
      align: [left, middle]
      wrap: false
      text: "0.5 сек"

  - elementId: kpi1-label
    elementType: text
    bounds: [75, 200, 240, 30]
    content:
      style: "$kpi_label"
      align: [left, middle]
      wrap: false
      text: ВХОД/ВЫХОД

  - elementId: kpi2-bg
    elementType: shape
    bounds: [350, 135, 270, 110]
    shapeName: rect
    fill:
      type: solid
      color: "$surface"
    border:
      style: solid
      width: 1
      color: "$border"

  - elementId: kpi2-num
    elementType: text
    bounds: [365, 145, 240, 50]
    content:
      style: "$kpi"
      fontSize: 40
      align: [left, middle]
      wrap: false
      text: "Real-Time"

  - elementId: kpi2-label
    elementType: text
    bounds: [365, 200, 240, 30]
    content:
      style: "$kpi_label"
      align: [left, middle]
      wrap: false
      text: АКТИВНЫЕ ПОСЕЩЕНИЯ

  - elementId: kpi3-bg
    elementType: shape
    bounds: [640, 135, 270, 110]
    shapeName: rect
    fill:
      type: solid
      color: "$surface"
    border:
      style: solid
      width: 1
      color: "$border"

  - elementId: kpi3-num
    elementType: text
    bounds: [655, 145, 240, 50]
    content:
      style: "$kpi"
      fontSize: 40
      align: [left, middle]
      wrap: false
      text: "24/7"

  - elementId: kpi3-label
    elementType: text
    bounds: [655, 200, 240, 30]
    content:
      style: "$kpi_label"
      align: [left, middle]
      wrap: false
      text: СБОР СТАТИСТИКИ

  - elementId: kpi4-bg
    elementType: shape
    bounds: [930, 135, 290, 110]
    shapeName: rect
    fill:
      type: solid
      color: "$surface"
    border:
      style: solid
      width: 1
      color: "$border"

  - elementId: kpi4-num
    elementType: text
    bounds: [945, 145, 260, 50]
    content:
      style: "$kpi"
      fontSize: 40
      align: [left, middle]
      wrap: false
      text: "API"

  - elementId: kpi4-label
    elementType: text
    bounds: [945, 200, 260, 30]
    content:
      style: "$kpi_label"
      align: [left, middle]
      wrap: false
      text: Face ID / БИОМЕТРИЯ

  - elementId: left-title
    elementType: text
    bounds: [60, 275, 400, 30]
    content:
      style: "$sectionTitle"
      fontSize: 20
      color: "$warning"
      align: [left, middle]
      wrap: false
      text: Что фиксирует система

  - elementId: left-body
    elementType: text
    bounds: [60, 315, 560, 280]
    content:
      style: "$body"
      fontSize: 17
      lineHeight: 1.6
      align: [left, top]
      text: |
        <p><span style="color:$warning;">✓</span> Кто пришёл, когда ушёл — точное время</p>
        <p><span style="color:$warning;">✓</span> Средняя длительность тренировки</p>
        <p><span style="color:$warning;">✓</span> Пиковые часы и дни загрузки</p>
        <p><span style="color:$warning;">✓</span> Какие зоны самые популярные</p>
        <p><span style="color:$warning;">✓</span> Кто перестал ходить — для реактивации</p>
        <p><span style="color:$warning;">✓</span> Незавершённые визиты — авто-закрытие</p>

  - elementId: right-bg
    elementType: shape
    bounds: [640, 270, 580, 340]
    shapeName: rect
    fill:
      type: solid
      color: "$surface"
    border:
      style: solid
      width: 1
      color: "$border"

  - elementId: right-title
    elementType: text
    bounds: [664, 290, 400, 30]
    content:
      style: "$sectionTitle"
      fontSize: 20
      align: [left, middle]
      wrap: false
      text: Для владельца клуба

  - elementId: right-body
    elementType: text
    bounds: [664, 335, 532, 250]
    content:
      style: "$body"
      fontSize: 16
      lineHeight: 1.6
      align: [left, top]
      text: |
        <p><strong style="color:$warning;">Понимаете загрузку</strong></p>
        <p>Знаете, когда пик — планируйте персонал</p>
        <p style="margin-top:10px"><strong style="color:$warning;">Видите отток</strong></p>
        <p>Клиент перестал ходить — реагируете за 3 дня</p>
        <p style="margin-top:10px"><strong style="color:$warning;">Оптимизируете зоны</strong></p>
        <p>Знаете, какое оборудование востребовано</p>

  - elementId: bottom-accent
    elementType: shape
    bounds: [60, 690, 40, 3]
    shapeName: rect
    fill:
      type: solid
      color: "$accent"

  - elementId: page-num
    elementType: text
    bounds: [1180, 688, 40, 20]
    content:
      style: "$caption"
      align: [right, middle]
      wrap: false
      text: "08"