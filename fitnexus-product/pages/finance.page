pageType: content
background:
  type: solid
  color: "$background"
elements:
  - elementId: header-badge
    elementType: text
    bounds: [60, 24, 160, 20]
    content:
      style: "$badge"
      align: [left, middle]
      wrap: false
      text: FIXINTEL PRO

  - elementId: page-title
    elementType: text
    bounds: [60, 60, 900, 45]
    content:
      style: "$title"
      align: [left, middle]
      wrap: false
      text: |
        <p>Finance — <span style="color:$success;">прозрачные финансы</span></p>

  - elementId: title-accent
    elementType: shape
    bounds: [60, 110, 50, 3]
    shapeName: rect
    fill:
      type: solid
      color: "$success"

  - elementId: feat1-bg
    elementType: shape
    bounds: [60, 135, 373, 160]
    shapeName: rect
    fill:
      type: solid
      color: "$surface"
    border:
      style: solid
      width: 1
      color: "$border"

  - elementId: feat1-icon
    elementType: icon
    bounds: [80, 155, 32, 32]
    iconName: "fas:wallet"
    fill:
      type: solid
      color: "$success"

  - elementId: feat1-title
    elementType: text
    bounds: [122, 153, 290, 30]
    content:
      fontSize: 18
      color: "$text"
      fontFamily: "Liter"
      align: [left, middle]
      wrap: false
      text: Кошелёк клиента

  - elementId: feat1-body
    elementType: text
    bounds: [80, 195, 333, 30]
    content:
      style: "$bodySmall"
      fontSize: 15
      lineHeight: 1.5
      align: [left, top]
      text: |
        <p>Баланс, пополнение, списание. Автоплатежи. История операций.</p>

  - elementId: feat2-bg
    elementType: shape
    bounds: [453, 135, 374, 160]
    shapeName: rect
    fill:
      type: solid
      color: "$surface"
    border:
      style: solid
      width: 1
      color: "$border"

  - elementId: feat2-icon
    elementType: icon
    bounds: [473, 155, 32, 32]
    iconName: "fas:credit-card"
    fill:
      type: solid
      color: "$success"

  - elementId: feat2-title
