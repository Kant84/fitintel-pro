    bounds: [473, 195, 334, 80]
    content:
      style: "$bodySmall"
      fontSize: 15
      lineHeight: 1.5
      align: [left, top]
      text: |
        <p>СБП, карты, Apple Pay, Google Pay, наличные. Всё в одной кассе.</p>

  - elementId: feat3-bg
